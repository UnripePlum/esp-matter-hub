#!/bin/bash

set -euo pipefail

DEFAULT_HOST="esp-matter-hub-659824.local"
HOST="${1:-$DEFAULT_HOST}"
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPL_FILE="$PROJECT_DIR/.hub_api_test_repl.sh"

if [[ ! -f "$REPL_FILE" ]]; then
  echo "Missing repl file: $REPL_FILE"
  exit 1
fi

chmod +x "$REPL_FILE"

HOST_ESCAPED="${HOST//\"/\\\"}"
SESSION_CMD="bash \"$REPL_FILE\" \"$HOST_ESCAPED\""

osascript - "$SESSION_CMD" <<'EOF'
on run argv
  tell application "Terminal"
    activate
    do script (item 1 of argv)
  end tell
end run
EOF
