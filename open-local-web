#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if [[ "$SCRIPT_PATH" != */* ]]; then
    SCRIPT_PATH="$(command -v "$SCRIPT_PATH")"
fi

PROJECT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
TERMINAL_REF_FILE="$PROJECT_DIR/.monitor.terminal_ref"
TARGET="${1:-}"
MAX_WAIT_SECONDS=15

extract_target_from_terminal_ref() {
    if [ ! -f "$TERMINAL_REF_FILE" ]; then
        return 1
    fi

    local ref window_id tab_index
    ref="$(tr -d '\r' < "$TERMINAL_REF_FILE")"

    if [[ "$ref" =~ window_id=([0-9]+) ]]; then
        window_id="${BASH_REMATCH[1]}"
    else
        return 1
    fi

    if [[ "$ref" =~ tab_index=([0-9]+) ]]; then
        tab_index="${BASH_REMATCH[1]}"
    else
        tab_index=""
    fi

    local dump
    dump="$(osascript <<EOF
tell application "Terminal"
    try
        if "$tab_index" is not "" then
            return contents of tab $tab_index of window id $window_id
        else
            return contents of selected tab of window id $window_id
        end if
    on error
        return ""
    end try
end tell
EOF
)"

    if [ -z "$dump" ]; then
        return 1
    fi

    local ip
    ip="$(printf '%s\n' "$dump" | grep -aEo 'sta ip:[[:space:]]*([0-9]{1,3}\.){3}[0-9]{1,3}' | sed -E 's/.*sta ip:[[:space:]]*//' | tail -n 1 || true)"
    if [ -n "$ip" ]; then
        printf 'http://%s\n' "$ip"
        return 0
    fi

    local mdns_url
    mdns_url="$(printf '%s\n' "$dump" | grep -aEo 'mDNS ready:[[:space:]]*http://[[:alnum:]-]+\.local' | sed -E 's/.*mDNS ready:[[:space:]]*//' | tail -n 1 || true)"
    if [ -n "$mdns_url" ]; then
        printf '%s\n' "$mdns_url"
        return 0
    fi
    return 1
}

if [ -z "$TARGET" ]; then
    TARGET=""
    for _ in $(seq 1 "$MAX_WAIT_SECONDS"); do
        if TARGET="$(extract_target_from_terminal_ref)"; then
            break
        fi
        sleep 1
    done

    if [ -z "$TARGET" ]; then
        echo "Error: neither sta ip nor mDNS URL found in run_esp32-s3 Terminal tab after ${MAX_WAIT_SECONDS}s."
        echo "Run ./run_esp32-s3 and wait until monitor prints 'sta ip:' or 'mDNS ready:' in that tab."
        exit 1
    fi
fi

if [[ "$TARGET" =~ ^https?:// ]]; then
    URL="$TARGET"
else
    URL="http://$TARGET"
fi

open "$URL"
echo "Opened: $URL"
